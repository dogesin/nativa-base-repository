# Variables para docker-compose (raíz del proyecto)
# Copia a .env y ajusta valores. No subas .env a git.


# --- Nombres de Contenedores ---
FRONTEND_CONTAINER_NAME=maiaa-frontend
BACKEND_CONTAINER_NAME=maiaa-backend
POSTGRES_CONTAINER_NAME=maiaa-db

# --- Puertos del Host ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5433

# --- Credenciales de Base de Datos ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret_password
POSTGRES_DB=maiaa_db
DATABASE_URL=postgresql://admin:secret_password@postgres:5432/maiaa_db