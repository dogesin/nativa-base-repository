# Configuración General del Proyecto
PROJECT_NAME="Base CRM Scan"
API_V1_PREFIX="/api/v1"

# --- Nombres de Contenedores ---
FRONTEND_CONTAINER_NAME=natvo-frontend
BACKEND_CONTAINER_NAME=natvo-backend
POSTGRES_CONTAINER_NAME=natvo-db

# --- Puertos del Host ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

# --- Credenciales de Base de Datos ---
POSTGRES_USER=natvo
POSTGRES_PASSWORD=natvo_secret
POSTGRES_DB=natvo_db
# Nota: Esta URL es para ejecución local fuera de Docker. 
# Docker Compose la sobrescribirá automáticamente para los contenedores.
DATABASE_URL=postgresql://natvo:natvo_secret@localhost:5432/natvo_db

# --- Seguridad ---
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
